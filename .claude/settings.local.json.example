    "backend_and_vectorizer": {
      "description": "Full-stack Data Focus (Backend API + Python Vectorizer)",
      "instructions": "Use this when mapping the data flow from ingestion to endpoint.",
      "deny": [
        "Read(./Svelte-Component-Library/**)",
        "Read(./client/**)",
        "Edit(./Svelte-Component-Library/**)",
        "Edit(./client/**)",
        
        "Read(**/node_modules/**)",
        "Read(**/.svelte-kit/**)",
        "Read(**/dist/**)",
