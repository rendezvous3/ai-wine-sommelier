    "ui_and_backend": {
      "description": "UI + Backend (Client, Component Library, and Backend API)",
      "instructions": "Use this when working across the frontend widget and backend API together.",
      "deny": [
        "Read(./vectorizer/**)",
        "Edit(./vectorizer/**)",

        "Read(**/node_modules/**)",
        "Read(**/.svelte-kit/**)",
        "Read(**/dist/**)",
