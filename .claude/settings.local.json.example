        "Read(**/pnpm-lock.yaml)",
        "Read(**/.storybook/**)",
        "Read(**/*.stories.ts)",
        "Read(**/*.stories.svelte)",
        "Read(**/coverage/**)",
        "Read(**/*.log)",
        "Read(**/.DS_Store)",
        "Read(**/.env)",
        "Read(**/.env.*)",
        "Read(./backend/.dev.vars)",
        "Read(**/.vscode/**)",
        "Read(**/.idea/**)",
